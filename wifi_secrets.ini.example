; Copy this file to wifi_secrets.ini (gitignored) and fill in real values.
; PlatformIO injects these into the build via build_flags interpolation
; in platformio.ini. Channel + BSSID stay in source — they're hardware
; identifiers, not secrets.
[wifi_secrets]
build_flags =
	-DWIFI_SSID=\"YOUR_SSID\"
	-DWIFI_PASSWORD=\"YOUR_PASSWORD\"
